# cloud-acp-gateway — example environment configuration
#
# Copy to `.env` (gitignored) and adjust: `cp env.example .env`. Shell env vars
# override these. For dev-only overrides layered on top of `.env`, drop a
# `.env.local` next to it (the Makefile includes it after `.env`). Values shown
# after `=` on commented lines are the built-in defaults; uncomment only what you
# need to override. The gateway speaks a single client transport: an SSE
# downstream (ACPG_SSE_PATH) + a POST upstream (ACPG_RPC_PATH).

# ─────────────────────────────────────────────────────────────── required ──
# Basic-auth credentials guarding the entire HTTP surface (SSE/POST, the SPA,
# /raw, and the /fs + /files + /history* JSON APIs). The gateway refuses to start
# without both. Only GET /healthz stays open.
ACPG_AUTH_USER=change-me
ACPG_AUTH_TOKEN=change-me-to-a-long-random-secret

# ──────────────────────────────────────────────────── network / transport ──
# host:port to bind.
#ACPG_LISTEN=0.0.0.0:8080
# SSE downstream path (the event-stream a client GETs) and POST upstream path
# (where it POSTs JSON-RPC frames). The client addresses POSTs to ?conn=<id>.
#ACPG_SSE_PATH=/acp/sse
#ACPG_RPC_PATH=/acp/rpc
# Interval (ms) for SSE keepalive comments, so proxies/load balancers don't idle
# the stream out. Non-positive/invalid falls back to 15000.
#ACPG_SSE_KEEPALIVE_MS=15000
# Max bytes for a single upstream POST body (16 MiB default), so an oversized or
# malformed frame can't be buffered unbounded. Non-positive/invalid falls back.
#ACPG_MAX_PAYLOAD=16777216

# ───────────────────────────────────────────────────────────────── agents ──
# Path to the agents manifest (agent name -> { cmd, args, cwd }). Relative paths
# resolve against the gateway install dir. Defaults to ./agents.json.
#ACPG_AGENTS_FILE=./agents.json
# Which configured agent a fresh client connects to. Defaults to the first entry
# in the agents file.
#ACPG_DEFAULT_AGENT=claude
# Default working directory for agent entries that omit a `cwd`. Defaults to the
# gateway user's home directory (NOT the install dir).
#ACPG_AGENT_CWD=/home/user
# Fallback single-agent config, used ONLY when no agents file exists:
#ACPG_AGENT_CMD=node_modules/.bin/claude-agent-acp
#ACPG_AGENT_ARGS=
# Which `claude` binary the Claude agent runs. Leave unset to use the SDK-bundled
# one; point at the host's standalone Claude Code (absolute path, e.g. the output
# of `command -v claude`) to use a newer build/default model. Forwarded to the
# agent as-is (consumed by the agent, not the gateway).
#CLAUDE_CODE_EXECUTABLE=/absolute/path/to/claude

# ──────────────────────────────────────────────────────── storage / ledger ──
# Directory for the append-only frame ledger (powers SSE resume) and, by
# default, the generated TLS material.
#ACPG_LEDGER_DIR=/data
# Bounded-ledger retention. 0/absent = unbounded (historical behavior). When a
# cap is exceeded the oldest frames are trimmed and the floor seq rises, so a
# client resuming from below the retained window is told to full-reload rather
# than replayed a gap.
#ACPG_LEDGER_MAX_FRAMES=0
#ACPG_LEDGER_MAX_BYTES=0

# ──────────────────────────────────────────────────────────────────── TLS ──
# TLS is on by default; set to "off" to serve plain HTTP (e.g. behind a TLS
# terminating proxy). With no cert/key configured the gateway generates a
# self-signed pair under ACPG_TLS_DIR and reuses it across restarts.
#ACPG_TLS=on
#ACPG_TLS_CERT=/path/to/fullchain.pem
#ACPG_TLS_KEY=/path/to/privkey.pem
#ACPG_TLS_DIR=/data/tls
# Extra Subject Alternative Names for the self-signed cert (comma-separated).
#ACPG_TLS_SAN=gateway.local,192.168.1.10

# ──────────────────────────────────────────────────────────────── console ──
# The bundled web console / SPA. Set to "off" to serve only the raw transport.
#ACPG_CONSOLE=on

# ─────────────────────────────────────────────────────────────── filesystem ──
# Root the console may browse and pick as an agent cwd. Everything must resolve
# within it (realpath + prefix guard). Defaults to the gateway user's home dir.
#ACPG_FS_ROOT=/home/user

# ─────────────────────────────────────────── agent-native history (optional) ──
# Where the gateway reads each agent's own session store to LIST/VIEW past
# conversations without resuming the agent. Defaults match the agents' own.
#CLAUDE_CONFIG_DIR=/home/user/.claude
#CODEX_HOME=/home/user/.codex
