# Build context excludes — keep the image build fast and clean. dist/, the web
# bundle, and node_modules are all (re)generated by `npm install` in the image.
.git
node_modules
**/node_modules
dist
public/vendor
web/dist
.env
*.log
ledger*.jsonl
*.sqlite
*.sqlite-shm
*.sqlite-wal
/data
data
test-results
playwright-report
.playwright
docs
